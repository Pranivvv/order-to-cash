<core:FragmentDefinition
  xmlns="sap.m"
  xmlns:core="sap.ui.core">
  <Dialog id="confirmDialog" title="Confirm">
    <content>
      <Text text="{dialog>/message}" class="sapUiSmallMargin" />
    </content>
    <beginButton>
      <Button text="OK" type="Emphasized" press="onConfirmOk" />
    </beginButton>
    <endButton>
      <Button text="Cancel" press="onConfirmCancel" />
    </endButton>
  </Dialog>
</core:FragmentDefinition>
