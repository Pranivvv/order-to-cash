{
  "_version": "1.59.0",
  "sap.app": {
    "id": "o2c.finance",
    "type": "application",
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "applicationVersion": {
      "version": "1.0.0"
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    },
    "icons": {
      "icon": "sap-icon://payment-approval"
    }
  },
  "sap.ui5": {
    "rootView": {
      "viewName": "o2c.finance.view.App",
      "type": "XML",
      "async": true,
      "id": "app"
    },
    "dependencies": {
      "minUI5Version": "1.120.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.ui.layout": {}
      }
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "uri": "i18n/i18n.properties"
      }
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "viewType": "XML",
        "viewPath": "o2c.finance.view",
        "controlId": "app",
        "controlAggregation": "pages",
        "async": true
      },
      "routes": [
        {
          "pattern": "",
          "name": "Invoices",
          "target": "Invoices"
        }
      ],
      "targets": {
        "Invoices": {
          "viewName": "Invoices",
          "viewId": "Invoices"
        }
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    }
  }
}
